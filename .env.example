# Copy to .env and fill in values. Never commit .env.

# Database
DATABASE_URL=postgresql://inboxzero:inboxzero@postgres:5432/inboxzero

# Redis (Celery broker)
REDIS_URL=redis://redis:6379/0

# Auth — use a random string of at least 32 characters in production
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI — Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Application
MAX_RETRY_ATTEMPTS=3
MAX_BATCH_SIZE=50
MAX_ITEM_CHARS=10000
DEBUG=false

# Rate limits
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SUBMIT=10/hour

# Frontend (Vercel) — server-side only, do NOT use NEXT_PUBLIC_ prefix
BACKEND_TUNNEL_URL=https://your-tunnel.trycloudflare.com
